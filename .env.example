# Copy to .env and adjust. Never commit real secrets.
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Per-service databases (each service owns its own). Wire these up when you
# replace the in-memory stores — see CLAUDE.md.
ORDER_DATABASE_URL=postgres://quickbite:quickbite@localhost:5432/order
MENU_DATABASE_URL=postgres://quickbite:quickbite@localhost:5432/menu
KITCHEN_DATABASE_URL=postgres://quickbite:quickbite@localhost:5432/kitchen

# Service URLs the gateway proxies to (local dev defaults)
MENU_URL=http://localhost:3001
ORDER_URL=http://localhost:3002
