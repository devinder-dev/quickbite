# Copy to .env and adjust. Never commit real secrets.

# Messaging
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Per-service Postgres databases (each service owns its own DB)
DATABASE_URL=postgres://quickbite:quickbite@localhost:5432/order_db    # used by order service
# MENU:         postgres://quickbite:quickbite@localhost:5432/menu_db
# KITCHEN:      postgres://quickbite:quickbite@localhost:5432/kitchen_db
# NOTIFICATION: postgres://quickbite:quickbite@localhost:5432/notification_db

# Redis — used for menu cache (TTL) and event idempotency (SETNX)
REDIS_URL=redis://localhost:6379

# Service URLs the gateway proxies to (local dev defaults)
MENU_URL=http://localhost:3001
ORDER_URL=http://localhost:3002
