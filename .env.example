# Copy to .env and adjust. Never commit real secrets.

# Messaging
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Per-service Postgres databases (each service owns its own DB).
# Each service reads DATABASE_URL from its own environment — docker-compose.yml
# sets the right value per container. Pick the line for whichever service you're
# running locally outside Docker.
DATABASE_URL=postgres://quickbite:quickbite@localhost:5432/order_db    # order service
# DATABASE_URL=postgres://quickbite:quickbite@localhost:5432/menu_db         # menu service
# DATABASE_URL=postgres://quickbite:quickbite@localhost:5432/kitchen_db      # kitchen service
# DATABASE_URL=postgres://quickbite:quickbite@localhost:5432/notification_db # notification service

# Redis — used for menu cache (TTL) and event idempotency (SETNX)
REDIS_URL=redis://localhost:6379

# Service URLs the gateway proxies to (local dev defaults)
MENU_URL=http://localhost:3001
ORDER_URL=http://localhost:3002
KITCHEN_URL=http://localhost:3003
